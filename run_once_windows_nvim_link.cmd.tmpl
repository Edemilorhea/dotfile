{{- if and (eq .chezmoi.os "windows") .syncNvim -}}
@echo off
:: 只在 Windows 環境且啟用 Neovim 同步時執行
:: 這個腳本用於建立 AppData\Local\nvim 到 .config\nvim 的 Directory Junction
:: 以解決 Neovim 在 Windows 和 Linux 上配置路徑不同的問題，且不需要管理員權限

set "TARGET_DIR=%USERPROFILE%\.config\nvim"
set "LINK_DIR=%LOCALAPPDATA%\nvim"

echo [Neovim Setup] Checking paths...

:: 1. 確保目標目錄存在
if not exist "%TARGET_DIR%" (
    echo [Neovim Setup] Creating target directory: %TARGET_DIR%
    mkdir "%TARGET_DIR%"
)

:: 2. 檢查舊的 nvim 連結或目錄是否存在
if exist "%LINK_DIR%" (
    :: 檢查是否為 Junction 或 Symlink
    dir /al "%LINK_DIR%" >nul 2>&1
    if errorlevel 1 (
        :: 不是連結，表示是實體目錄，我們需要備份它
        :: 取得當前時間用於備份名稱 (YYYYMMDD_HHMMSS)
        for /f "tokens=2-4 delims=/ " %%a in ('date /t') do (set mydate=%%c%%a%%b)
        for /f "tokens=1-2 delims=/:" %%a in ('time /t') do (set mytime=%%a%%b)
        set "mytime=%mytime: =0%"
        set "BACKUP_DIR=%LINK_DIR%_backup_%mydate%_%mytime%"
        
        echo [Neovim Setup] Existing real directory found. Backing up to: !BACKUP_DIR!
        ren "%LINK_DIR%" "nvim_backup_%mydate%_%mytime%"
    ) else (
        :: 是連結，不處理，直接退出腳本
        echo [Neovim Setup] Junction already exists.
        exit /b 0
    )
)

:: 3. 建立 Directory Junction (不需要系統管理員權限)
echo [Neovim Setup] Creating Junction: %LINK_DIR% -^> %TARGET_DIR%
mklink /J "%LINK_DIR%" "%TARGET_DIR%" >nul

echo [Neovim Setup] Complete.
{{- end -}}
