{{- if and (eq .chezmoi.os "windows") .syncNvim -}}
# 只在 Windows 環境且啟用 Neovim 同步時執行
# 這個腳本用於建立 AppData\Local\nvim 到 .config\nvim 的 Directory Junction
# 以解決 Neovim 在 Windows 和 Linux 上配置路徑不同的問題

$TargetDir = Join-Path $env:USERPROFILE ".config\nvim"
$LinkDir = Join-Path $env:LOCALAPPDATA "nvim"

# 確保目標目錄存在
if (-Not (Test-Path $TargetDir)) {
    Write-Host "Creating target directory: $TargetDir"
    New-Item -ItemType Directory -Force -Path $TargetDir | Out-Null
}

# 檢查連結目錄是否存在
if (Test-Path $LinkDir) {
    # 如果已存在的是目錄，且不是一個連結，則備份它
    $Item = Get-Item $LinkDir
    if ($Item.Attributes -match "ReparsePoint") {
        Write-Host "Junction already exists at $LinkDir"
        exit 0
    } else {
        $BackupDir = "${LinkDir}_backup_$(Get-Date -Format 'yyyyMMdd_HHmmss')"
        Write-Host "Backing up existing nvim directory to $BackupDir"
        Rename-Item -Path $LinkDir -NewName $BackupDir
    }
}

# 建立 Directory Junction (不需要系統管理員權限)
Write-Host "Creating Junction: $LinkDir -> $TargetDir"
cmd /c mklink /J "$LinkDir" "$TargetDir"

Write-Host "Neovim junction created successfully."
{{- end -}}
