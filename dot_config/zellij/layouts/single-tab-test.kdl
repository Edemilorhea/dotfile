// 單一 tab 測試配置 (避免 Zellij 下載 bug)
layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                format_left "TEST-LEFT"
                format_center "TEST-CENTER"
                format_right "TEST-RIGHT"
            }
        }
    }
    
    // 只建立一個 tab
    tab name="main" {
        pane
    }
}
