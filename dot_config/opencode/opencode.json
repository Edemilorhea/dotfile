        "google": {
            "options": {
                "projectId": "gen-lang-client-0877567430"
            },
            "models": {
                "gemini-2.5-flash": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingBudget": 8192,
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-2.5-pro": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingBudget": 8192,
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3-flash-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3-pro-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3.1-pro-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                }
            }
        }
