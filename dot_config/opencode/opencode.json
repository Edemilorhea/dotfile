{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "opencode-gemini-auth@latest",
        "opencode-anthropic-oauth@latest",
        "@franlol/opencode-md-table-formatter@latest",
        "opencode-pty",
        // "@daytonaio/opencode",
        // "opencode-helicone-session",
        // "@nick-vi/opencode-type-inject",
        "@mohak34/opencode-notifier@latest"
        // "@plannotator/opencode@latest",
        // "opencode-supermemory@latest"
    ],
    "instructions": [
        "~/.config/opencode/plugin/shell-strategy/shell_strategy.md"
    ],
    "autoupdate": true,
    "default_agent": "OpenAgent",
    "provider": {
        "google": {
            "options": {
                "projectId": "gen-lang-client-0877567430"
            },
            "models": {
                "gemini-2.5-flash": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingBudget": 8192,
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-2.5-pro": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingBudget": 8192,
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3-flash-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3-pro-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                }
            }
        }
    },
    "permission": {
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        },
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "lsp": "allow",
        "edit": "ask",
        "bash": {
            "*": "ask",
            "ls *": "allow",
            "ls": "allow",
            "pwd": "allow",
            "cat *": "allow",
            "find *": "allow",
            "git status*": "allow",
            "git diff*": "allow",
            "git log*": "allow",
            "dotnet --info*": "allow",
            "dotnet --list-*": "allow",
            "dotnet build*": "allow",
            "dotnet test*": "allow",
            "npm install*": "allow",
            "npm run *": "allow",
            "pnpm install*": "allow",
            "pnpm run *": "allow",
            "yarn *": "allow",
            "git add *": "ask",
            "git commit*": "ask",
            "git push*": "ask",
            "git merge*": "ask",
            "git rebase*": "ask",
            "rm *": "deny",
            "rm -rf *": "deny",
            "mv *": "ask",
            "cp *": "ask"
        },
        "task": "ask",
        "todoread": "allow",
        "todowrite": "ask",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "external_directory": "ask",
        "doom_loop": "allow"
    },
    "agent": {
        "plan": {
            "permission": {
                "edit": "deny"
            }
        },
        "OpenAgent": {
            "permission": {
                "edit": "deny"
            }
        }
    },
    "mcp": {
        "notebooklm": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "notebooklm-mcp@latest"
            ],
            "enabled": true
        },
        "linear": {
            "type": "remote",
            "url": "https://mcp.linear.app/mcp",
            // "command": [
            //     "npx",
            //     "-y",
            //     "mcp-remote",
            //     "https://mcp.linear.app/mcp"
            // ],
            "enabled": true,
            "timeout": 5000
        }
    }
}
